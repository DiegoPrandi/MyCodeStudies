A = [2 -25 12 6; 5 -5 8 -5; 12 6 5 9; 5 -10 40 11; 7 9 7 -4]
B = [2 -1 6 -6 1; -10 12 8 14 5; 9 -7 6 5 8; 1 -3 -9 4 -2]
C = [2 5 0 1 4; 3 -9 7 3 6; 10 5 -1 4 -8; -3 2 1 4 2]

M = A * B
N = B + C

res_a = M(4,3) + N(3,4)
res_b = M(3,5) - 3 * N(2,3)
disp("Resultado A:", res_a)
disp("Resultado B:", res_b)
